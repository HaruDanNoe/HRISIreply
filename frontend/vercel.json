{
  "version": 2,
  "name": "hrisi-reply-frontend",
  "framework": "vite",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api-proxy/:path*",
      "destination": "https://dtfj.helioho.st/backendHRIS/backend/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
