{
  "version": 2,
  "name": "hrisi-reply",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api-proxy/(.*)",
      "destination": "https://selective-melodie-ireply-bd5411b8.koyeb.app/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/((?!api-proxy/).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
