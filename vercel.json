{
  "version": 2,
  "name": "hrisi-reply",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api-proxy/(.*)",
      "destination": "https://dtfj.helioho.st/backendHRIS/backend/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    },
    {
      "source": "/((?!api-proxy/).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
